# DevAssist MCP Server Configuration
# Copy this file to .env and fill in your values

# GitHub Personal Access Token (required for higher API rate limits)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=

# GitHub API Base URL (default: https://api.github.com)
# GITHUB_API_BASE_URL=https://api.github.com

# Codeforces API Base URL (default: https://codeforces.com/api)
# CODEFORCES_API_BASE_URL=https://codeforces.com/api

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/devassist.log

# HTTP Client timeout in seconds
HTTP_TIMEOUT=30

# Maximum retry attempts for failed API requests
MAX_RETRIES=3
